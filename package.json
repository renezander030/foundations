{
  "name": "foundations-cli",
  "version": "0.2.0",
  "description": "Check your own network before you google. A trust-ordered sweep of your proven tools, notes and code, so your AI agent (and you) build on practice, not loose ends.",
  "type": "module",
  "bin": {
    "foundations": "bin/foundations"
  },
  "scripts": {
    "demo": "node bin/foundations check \"vector search caching\" --human",
    "test": "node --test",
    "smoke": "node bin/foundations check \"vector search caching deploy\" --human"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "Rene Zander",
