  },
  "homepage": "https://github.com/renezander030/foundations#readme",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai-agent",
    "llm",
    "claude",
    "cli",
    "context-engineering",
    "trust",
